@echo off
cd /d "%~dp0"
title Личный бюджет — сервер

:: Убить старый процесс на порту 3500 если висит
for /f "tokens=5" %%a in ('netstat -ano 2^>nul ^| findstr ":3500 "') do (
    taskkill /F /PID %%a >nul 2>&1
)

echo.
echo  ====================================
echo   Личный бюджет — сервер запущен
echo  ====================================
echo.
echo  Не закрывайте это окно!
echo  Телефон: откройте браузер и введите адрес из QR-страницы
echo  Остановить: закройте это окно или нажмите Ctrl+C
echo.

python start.py

echo.
echo  Сервер остановлен.
pause
